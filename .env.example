# GitHub API (recommended for local dev — avoids 60 req/hr unauthenticated limit)
# Create at: https://github.com/settings/tokens — no scopes needed for public data
GITHUB_TOKEN=

# Analytics (optional — leave blank to disable)
# Plausible: your site domain as registered in Plausible
VITE_PLAUSIBLE_DOMAIN=vskanna.dev

# Umami: website ID from your Umami dashboard
VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
